# Root .env is the single runtime source for both apps/web and apps/api.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8001/api
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# Leave DATABASE_URL unset to use the default SQLite DB at apps/api/pmo_ops_p1_schema.db
# DATABASE_URL=sqlite:///C:/path/to/pmo-ops-portal/apps/api/pmo_ops_p1_schema.db

# Public holiday sync
PUBLIC_HOLIDAY_API_SERVICE_KEY=
# PUBLIC_HOLIDAY_PROVIDER=kr_public_data
# PUBLIC_HOLIDAY_API_BASE_URL=https://apis.data.go.kr/B090041/openapi/service/SpcdeInfoService/getRestDeInfo
# PUBLIC_HOLIDAY_API_TIMEOUT_SECONDS=15
