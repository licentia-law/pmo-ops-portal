{
  "name": "pmo-ops-portal",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web",
    "packages/shared-types",
    "packages/shared-ui",
    "packages/shared-mocks"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @pmo/web -- --hostname 127.0.0.1 --port 3000",
    "build:web": "npm run build -w @pmo/web",
    "lint:web": "npm run lint -w @pmo/web",
    "typecheck": "npm run typecheck -w @pmo/shared-types && npm run typecheck -w @pmo/shared-ui && npm run typecheck -w @pmo/shared-mocks && npm run typecheck -w @pmo/web",
    "dev:api": "node scripts/dev-api.mjs"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
